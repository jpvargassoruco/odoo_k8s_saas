<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_instance_ready" model="mail.template">
            <field name="name">SaaS Instance Ready</field>
            <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
            <field name="subject">Your Odoo instance is ready! 🚀</field>
            <field name="email_from">{{ (object.partner_id.company_id.email or user.email) }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                    <div style="background: linear-gradient(135deg,#6366f1,#8b5cf6); padding: 30px; border-radius: 10px 10px 0 0; text-align: center;">
                        <h1 style="color: white; margin: 0;">Your Odoo is ready! 🚀</h1>
                    </div>
                    <div style="background: #f8fafc; padding: 30px; border-radius: 0 0 10px 10px;">
                        <p>Hello <strong><t t-out="object.partner_id.name"/></strong>,</p>
                        <p>Your Odoo <t t-out="object.odoo_version"/> instance has been successfully provisioned and is ready to use.</p>
                        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin: 20px 0;">
                            <p style="margin: 0 0 8px;"><strong>🌐 URL:</strong>
                                <a t-att-href="object.url" style="color: #6366f1;">
                                    <t t-out="object.url"/>
                                </a>
                            </p>
                            <p style="margin: 0 0 8px;"><strong>📦 Version:</strong> Odoo <t t-out="object.odoo_version"/></p>
                            <p style="margin: 0;"><strong>👤 Login:</strong> Use your email address</p>
                        </div>
                        <p>If you have any questions, our support team is here to help.</p>
                        <p style="color: #64748b; font-size: 12px; margin-top: 30px;">
                            This is an automated message from Aeisoftware SaaS Platform.
                        </p>
                    </div>
                </div>
            </field>
        </record>
    </data>
</odoo>
