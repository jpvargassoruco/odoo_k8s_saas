<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Provision pending instances (non-blocking) -->
        <record id="cron_provision_instances" model="ir.cron">
            <field name="name">SaaS: Provision Pending Instances</field>
            <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_provision_pending()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
            <field name="priority">5</field>
        </record>

        <!-- Cron: Check provisioning status (sync state with portal) -->
        <record id="cron_check_provisioning_status" model="ir.cron">
            <field name="name">SaaS: Check Provisioning Status</field>
            <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_provisioning_status()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
            <field name="priority">10</field>
        </record>
    </data>
</odoo>
