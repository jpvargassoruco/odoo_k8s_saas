<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template — SaaS Fields Tab -->
    <record id="view_product_template_saas_form" model="ir.ui.view">
        <field name="name">product.template.saas.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="SaaS Plan" invisible="not is_saas_plan">
                    <group>
                        <group string="Instance Configuration">
                            <field name="saas_odoo_version"/>
                            <field name="saas_workers"/>
                            <field name="saas_domain_suffix"/>
                        </group>
                        <group string="Provisioning">
                            <field name="saas_db_template"/>
                            <field name="saas_addons_repo"/>
                            <field name="saas_custom_image"/>
                        </group>
                    </group>
                </page>
            </notebook>
            <field name="name" position="after">
                <field name="is_saas_plan" widget="boolean_toggle"/>
            </field>
        </field>
    </record>
</odoo>
