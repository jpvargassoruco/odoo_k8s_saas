<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sale Order — SaaS Instances Smart Button -->
    <record id="view_sale_order_saas" model="ir.ui.view">
        <field name="name">sale.order.saas.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_saas_instances"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-server"
                        invisible="saas_instance_count == 0">
                    <field name="saas_instance_count" widget="statinfo" string="Instances"/>
                </button>
            </div>
        </field>
    </record>
</odoo>
