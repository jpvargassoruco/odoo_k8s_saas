<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings — SaaS Portal section -->
    <record id="res_config_settings_view_saas" model="ir.ui.view">
        <field name="name">res.config.settings.saas</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <div id="saas_settings" position="before">
                <h2>SaaS Provisioning Portal</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Portal URL</span>
                            <div class="text-muted">The base URL of the SaaS provisioning portal</div>
                            <div class="content-group">
                                <field name="saas_portal_url" class="o_input"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">API Key</span>
                            <div class="text-muted">X-API-Key header value for portal authentication</div>
                            <div class="content-group">
                                <field name="saas_api_key" password="True" class="o_input"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </field>
    </record>
</odoo>
