<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings — SaaS Portal section (Odoo 18 app/block/setting format) -->
    <record id="res_config_settings_view_saas" model="ir.ui.view">
        <field name="name">res.config.settings.saas</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SaaS Portal" string="SaaS Portal" name="odoo_k8s_saas" groups="base.group_system">
                    <block title="SaaS Provisioning Portal" name="saas_portal_settings">
                        <setting string="Portal URL" help="The base URL of the SaaS provisioning portal">
                            <field name="saas_portal_url"/>
                        </setting>
                        <setting string="API Key" help="X-API-Key header value for portal authentication">
                            <field name="saas_api_key" password="True"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
